# คัดลอกไฟล์นี้เป็น .env.local สำหรับรันในเครื่อง (ห้าม commit .env.local ขึ้น git)
# ค่าจริงสำหรับ production ให้ตั้งใน Vercel > Project Settings > Environment Variables

# จาก credentials.json ของ Service Account (Google Cloud Console > IAM & Admin > Service Accounts)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# ก็อปค่า private_key จาก credentials.json มาทั้งหมด (เก็บ \n ไว้ตามเดิม ใส่ในเครื่องหมายคำพูด)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXXXXXXXXXX\n-----END PRIVATE KEY-----\n"

# Spreadsheet ID จาก URL ของ Google Sheet
# https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SHEET_ID=

# ชื่อแท็บที่ใช้เก็บข้อมูล (ถ้าไม่ตั้งค่า ระบบจะสร้างแท็บ "Complaints" ให้อัตโนมัติ)
GOOGLE_SHEET_TAB_NAME=Complaints
